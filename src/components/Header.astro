---
import { SITE_TITLE } from '../consts';
---

<header class="mb-6 border-b border-zinc-200 pb-6 dark:border-zinc-800">
  <div class="mb-2 flex items-start justify-between">
    <a
      href="/"
      class="text-2xl font-semibold tracking-tight text-zinc-900 no-underline transition-opacity hover:opacity-70 dark:text-zinc-100"
    >
      {SITE_TITLE}
    </a>
    <nav class="flex items-center gap-4 pt-1 text-sm text-zinc-500 dark:text-zinc-400">
      <a href="/projects" class="editorial-link transition-colors hover:text-zinc-900 dark:hover:text-zinc-100"
        >Projects</a
      >
      <a href="/blog" class="editorial-link transition-colors hover:text-zinc-900 dark:hover:text-zinc-100"
        >Blog</a
      >
    </nav>
  </div>
  <p class="text-base text-zinc-600 dark:text-zinc-400">
    <em class="accent-text">Compiler Engineering Intern @ Intel</em> · Cornell CS &amp; Mathematics
  </p>
  <p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
    Formal methods · Compilers · Programming languages ·
    <span class="accent-text">U.S. Top Secret Security Clearance</span>
  </p>
  <p class="mt-1 text-xs text-zinc-400 dark:text-zinc-500">San Jose, CA / Bay Area · Ithaca, NY · Los Angeles, CA</p>
</header>
